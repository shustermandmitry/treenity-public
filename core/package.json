{
  "name": "@shustermandmitry/treenity-core",
  "version": "3.2.0",
  "description": "Composable typed tree engine — three primitives, everything else composes. Nodes, components, contexts.",
  "type": "module",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "license": "FSL-1.1-MIT",
  "author": "Treenity <hello@treenity.ai> (https://treenity.ai)",
  "homepage": "https://github.com/treenity-ai/treenity",
  "repository": {
    "type": "git",
    "url": "https://github.com/treenity-ai/treenity.git"
  },
  "keywords": [
    "treenity",
    "tree",
    "composable",
    "typed",
    "ecs",
    "node",
    "component",
    "context",
    "mcp",
    "ai-native"
  ],
  "imports": {
    "#*": {
      "development": "./src/*.ts",
      "default": "./dist/*.js"
    }
  },
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./*": {
      "development": "./src/*.ts",
      "types": "./dist/*.d.ts",
      "default": "./dist/*.js"
    }
  },
  "treenity": {
    "clients": "./src/mods/clients.ts",
    "servers": "./src/mods/servers.ts"
  },
  "files": [
    "dist",
    "src",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepack": "npm run build",
    "test": "tsx --conditions development --test src/**/*.test.ts",
    "dev:server": "tsx --conditions development --watch src/server/main.ts ../root.json",
    "schema": "tsx --conditions development src/schema/extract-schemas.ts ../mods ../packages"
  },
  "dependencies": {},
  "peerDependencies": {
    "@trpc/server": ">=11",
    "fast-json-patch": ">=3",
    "immer": ">=11",
    "quickjs-emscripten": ">=0.32",
    "sift": ">=17",
    "zod": ">=4",
    "mongodb": ">=6",
    "grammy": ">=1.39",
    "@orama/orama": ">=3"
  },
  "peerDependenciesMeta": {
    "mongodb": { "optional": true },
    "grammy": { "optional": true },
    "@orama/orama": { "optional": true },
    "quickjs-emscripten": { "optional": true }
  },
  "devDependencies": {
    "@orama/orama": "^3.1.18",
    "@trpc/server": "^11.9.0",
    "fast-json-patch": "^3.1.1",
    "grammy": "^1.39.3",
    "immer": "^11.1.4",
    "mongodb": "^7.1.0",
    "quickjs-emscripten": "^0.32.0",
    "sift": "^17.1.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "zod": "^4.3.6"
  }
}
